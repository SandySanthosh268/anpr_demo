# ─── Application ───────────────────────────────────────────────
APP_NAME="ANPR System"
# APP_ENV=production          # development | production
# DEBUG=false
APP_ENV=development      # enables auto table-create on first run
DEBUG=true
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:Sandy%402026@localhost:5432/anpr
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Camera ────────────────────────────────────────────────────
RTSP_URL=rtsp://admin:Admin%40123@192.168.1.72:554/stream1
CAMERA_NAME=Gate1
FRAME_SKIP=5                # Process every Nth frame
RECONNECT_DELAY=5           # Seconds between reconnect attempts
MAX_RECONNECT_ATTEMPTS=10

# ─── Detection ─────────────────────────────────────────────────
YOLO_MODEL_PATH="/home/ubuntu/Documents/sandy_files/plate_paddleOCR/model/number_plate_yolov8s_v2.pt"
YOLO_CONFIDENCE=0.25
YOLO_IOU=0.45
DETECTION_DEVICE=cpu        # cpu | 0 | cuda:0

# ─── OCR ───────────────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=0.7
OCR_LANG=en

# ─── Validation ────────────────────────────────────────────────
PLATE_CONFIDENCE_MIN=0.6
DUPLICATE_WINDOW_SECONDS=30  # Suppress same plate within N seconds

# ─── Snapshots ─────────────────────────────────────────────────
SNAPSHOT_DIR=snapshots
SNAPSHOT_RETENTION_DAYS=30

# ─── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ─── WebSocket ─────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30    # Seconds
